#!/usr/bin/env bash
set -euo pipefail

# clone_github_repository — clone a GitHub repo with correct identity and destination
#
# Detects the GitHub account from the repo owner, sets up the correct SSH
# remote alias and PAT, and clones to the appropriate directory based on
# the intended purpose (contributor, external, or temporary).

# --- Ensure user paths are available (non-interactive shells skip .bashrc) ---
for _d in "$HOME/.local/bin" "$HOME/bin"; do
  [[ -d "$_d" && ":$PATH:" != *":$_d:"* ]] && PATH="$_d:$PATH"
done
if [[ -s "$HOME/.nvm/nvm.sh" ]]; then
  export NVM_DIR="$HOME/.nvm"
  source "$NVM_DIR/nvm.sh" 2>/dev/null || true
fi
export PATH

# --- Defaults ---
REPO_URL=""
ACCOUNT=""        # auto-detected; override with --account
PURPOSE="contributor"  # contributor | external | temporary
DIR_NAME=""       # override clone directory name

usage() {
  cat <<'EOF'
Usage: clone_github_repository --url <URL_OR_OWNER/REPO> [OPTIONS]

Options:
  --url URL          GitHub URL or owner/repo shorthand (required)
  --account ACCOUNT  Force a specific account from github-accounts.json (default: auto-detect)
  --purpose PURPOSE  Clone purpose (default: contributor)
                       contributor  → ~/Projects/<repo>
                       external    → ~/external-github-repos/<repo>
                       temporary   → /tmp/github/<repo>
  --name DIR_NAME    Override the clone directory name

Examples:
  clone_github_repository --url https://github.com/myuser/my-project
  clone_github_repository --url some-org/private-repo --account work
  clone_github_repository --url https://github.com/torvalds/linux --purpose temporary
  clone_github_repository --url some-org/private-repo --account work --purpose external
EOF
  exit "${1:-0}"
}

# --- Parse arguments ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --url)      REPO_URL="$2"; shift 2 ;;
    --account)  ACCOUNT="$2"; shift 2 ;;
    --purpose)  PURPOSE="$2"; shift 2 ;;
    --name)     DIR_NAME="$2"; shift 2 ;;
    --help|-h)  usage 0 ;;
    *)
      echo "Error: Unknown flag: $1" >&2
      usage 1
      ;;
  esac
done

if [[ -z "$REPO_URL" ]]; then
  echo "Error: --url is required" >&2
  usage 1
fi

# --- Parse the URL into owner and repo ---
# Accepts:
#   https://github.com/owner/repo
#   https://github.com/owner/repo.git
#   git@github.com:owner/repo.git
#   git@github-personal:owner/repo.git
#   owner/repo
OWNER=""
REPO=""

parse_url() {
  local url="$1"
  # Strip trailing .git
  url="${url%.git}"
  # Strip trailing /
  url="${url%/}"

  if [[ "$url" =~ ^https?://github\.com/([^/]+)/([^/]+)$ ]]; then
    OWNER="${BASH_REMATCH[1]}"
    REPO="${BASH_REMATCH[2]}"
  elif [[ "$url" =~ ^git@github[^:]*:([^/]+)/([^/]+)$ ]]; then
    OWNER="${BASH_REMATCH[1]}"
    REPO="${BASH_REMATCH[2]}"
  elif [[ "$url" =~ ^([^/]+)/([^/]+)$ ]]; then
    OWNER="${BASH_REMATCH[1]}"
    REPO="${BASH_REMATCH[2]}"
  else
    echo "Error: Cannot parse URL: $url" >&2
    echo "Expected: https://github.com/owner/repo, git@github.com:owner/repo.git, or owner/repo" >&2
    exit 1
  fi
}

parse_url "$REPO_URL"
echo "Parsed: owner=$OWNER repo=$REPO"

# --- Source shared GitHub account resolver ---
_lib_path=""
_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
for _p in \
  "${OPENCLAW_DIR:-$HOME/.openclaw}/lib/resolve_github_account" \
  "$_script_dir/../../../lib/resolve_github_account" \
; do
  if [[ -f "$_p" ]]; then
    _lib_path="$_p"
    break
  fi
done

if [[ -z "$_lib_path" ]]; then
  echo "Error: resolve_github_account library not found." >&2
  echo "Install it with: ./install.sh or copy lib/resolve_github_account to ~/.openclaw/lib/" >&2
  exit 1
fi

source "$_lib_path"

# --- Detect account from owner ---
if [[ -z "$ACCOUNT" ]]; then
  ACCOUNT="$(resolve_account_for_owner "$OWNER")"
  if [[ -z "$ACCOUNT" ]]; then
    echo "Error: Could not resolve account for owner '$OWNER'." >&2
    echo "Configure accounts in ~/.openclaw/github-accounts.json" >&2
    exit 1
  fi
  echo "Account: $ACCOUNT (auto-detected for owner '$OWNER')"
else
  echo "Account: $ACCOUNT (explicitly set)"
fi

# --- Set up credentials ---
set_github_identity "$ACCOUNT"

SSH_HOST="$(get_account_field "$ACCOUNT" "ssh_host")"
if [[ -z "$SSH_HOST" ]]; then
  echo "Warning: No ssh_host configured for account '$ACCOUNT'. Using github.com." >&2
  SSH_HOST="github.com"
fi

# --- Determine destination directory ---
CLONE_NAME="${DIR_NAME:-$REPO}"
DEST_DIR=""

case "$PURPOSE" in
  contributor)
    DEST_DIR="$HOME/Projects/$CLONE_NAME"
    ;;
  external)
    DEST_DIR="$HOME/external-github-repos/$CLONE_NAME"
    ;;
  temporary|temp)
    DEST_DIR="/tmp/github/$CLONE_NAME"
    ;;
  *)
    echo "Error: Unknown purpose '$PURPOSE'. Use: contributor, external, or temporary." >&2
    exit 1
    ;;
esac

# --- Check if destination already exists ---
if [[ -d "$DEST_DIR" ]]; then
  echo "Error: Destination already exists: $DEST_DIR" >&2
  echo "If you want to re-clone, remove it first or use --name to pick a different name." >&2
  exit 1
fi

# Ensure parent directory exists
mkdir -p "$(dirname "$DEST_DIR")"

# --- Build clone URL using SSH host alias ---
CLONE_URL="git@${SSH_HOST}:${OWNER}/${REPO}.git"

echo ""
echo "Cloning:"
echo "  From:    $CLONE_URL"
echo "  To:      $DEST_DIR"
echo "  Account: $ACCOUNT (SSH host: $SSH_HOST)"
echo "  Purpose: $PURPOSE"
echo ""

# --- Clone ---
git clone "$CLONE_URL" "$DEST_DIR"

# --- Verify ---
if [[ ! -d "$DEST_DIR/.git" ]]; then
  echo "Error: Clone appears to have failed — no .git directory found." >&2
  exit 1
fi

# Verify the remote is set correctly
ACTUAL_REMOTE="$(git -C "$DEST_DIR" remote get-url origin 2>/dev/null)"
echo ""
echo "Clone successful!"
echo "  Directory: $DEST_DIR"
echo "  Remote:    $ACTUAL_REMOTE"
echo "  Account:   $ACCOUNT"

# --- Post-clone: verify gh access ---
if command -v gh &>/dev/null && [[ -n "${GH_TOKEN:-}" ]]; then
  if gh api "repos/$OWNER/$REPO" -q '.full_name' &>/dev/null; then
    PERMS="$(gh api "repos/$OWNER/$REPO" -q '[if .permissions.admin then "admin" elif .permissions.push then "push" elif .permissions.pull then "pull" else "none" end] | .[0]' 2>/dev/null || echo "unknown")"
    echo "  gh access: verified ($PERMS)"
  else
    echo "  gh access: could not verify (token may lack repo scope for this repo)"
  fi
fi

echo ""
echo "Done. cd $DEST_DIR"
